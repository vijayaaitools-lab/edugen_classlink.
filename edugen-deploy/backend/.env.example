# PostgreSQL connection string (get from Neon.tech - free tier)
DATABASE_URL=postgresql://user:password@host/dbname

# Secret key for session cookies (make this random and long!)
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app

# Port (Render sets this automatically)
PORT=3000
